// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String    @id @default(cuid())
  email                String    @unique
  password             String?
  name                 String?
  plan                 String    @default("free") // free, basic, pro, business
  tokens               Int       @default(3)
  bonusTokens          Int       @default(0)
  tokenPackPurchased   Boolean   @default(false)
  tokensResetAt        DateTime  @default(now())
  stripeCustomerId     String?
  stripeSubscriptionId String?
  resetToken           String?   @unique
  resetTokenExpires    DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  business  Business?
  contacts  Contact[]
  documents Document[]
}

model Business {
  id      String  @id @default(cuid())
  userId  String  @unique
  name    String
  address String?
  city    String?
  state   String?
  zip     String?
  country String?
  phone   String?
  email   String?
  website String?
  taxId   String?
  logoUrl String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Contact {
  id        String   @id @default(cuid())
  userId    String
  name      String
  company   String?
  email     String?
  phone     String?
  address   String?
  city      String?
  state     String?
  zip       String?
  country   String?
  notes     String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Document {
  id         String   @id @default(cuid())
  userId     String
  type       String // invoice, receipt, statement
  number     String?
  clientName String?
  total      Float?
  data       String // JSON string with full document data
  status     String   @default("draft") // draft, sent, paid
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model GuestUsage {
  id        String   @id @default(cuid())
  ip        String   @unique
  tokens    Int      @default(3)
  weekStart DateTime @default(now())
  createdAt DateTime @default(now())
}

model ProcessedEvent {
  id        String   @id // Stripe event ID
  createdAt DateTime @default(now())
}
